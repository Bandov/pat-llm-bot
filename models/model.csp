#define OWNER_COUNT 2;
#define OWNER_POS_IN 0;
#define OWNER_POS_NEAR 1;
#define OWNER_POS_FAR 2;
#define KEY_POS_IN 0;
#define KEY_POS_FAR 1;
#define KEY_POS_WITH_OWNER 2;
#define DOOR_STATUS_OPEN 0;
#define DOOR_STATUS_UNLOCKED 1;
#define DOOR_STATUS_LOCKED 2;
#define ENGINE_OFF 0;
#define ENGINE_ON 1;
#define CAR_STOPPED 0;
#define CAR_DRIVING 1;
#define FUEL_EMPTY 0;
#define FUEL_HALF 50;
#define FUEL_FULL 100;

var ownerPositions[OWNER_COUNT] = [OWNER_POS_FAR, OWNER_POS_FAR];
var keyPosition = KEY_POS_FAR;
var doorStatus = DOOR_STATUS_LOCKED;
var engineState = ENGINE_OFF;
var carMotion = CAR_STOPPED;
var fuelLevel = FUEL_FULL;

owner_pos() = 
    [ownerPositions[0] == OWNER_POS_FAR] owner0_approach{ownerPositions[0] = OWNER_POS_NEAR;} -> owner_pos()
    []
    [ownerPositions[0] == OWNER_POS_NEAR && doorStatus == DOOR_STATUS_OPEN] owner0_enter{ownerPositions[0] = OWNER_POS_IN;} -> owner_pos()
    []
    [ownerPositions[0] == OWNER_POS_IN && doorStatus == DOOR_STATUS_OPEN] owner0_exit{ownerPositions[0] = OWNER_POS_NEAR;} -> owner_pos()
    []
    [ownerPositions[0] == OWNER_POS_NEAR] owner0_leave{ownerPositions[0] = OWNER_POS_FAR;} -> owner_pos()
    []
    [ownerPositions[1] == OWNER_POS_FAR] owner1_approach{ownerPositions[1] = OWNER_POS_NEAR;} -> owner_pos()
    []
    [ownerPositions[1] == OWNER_POS_NEAR && doorStatus == DOOR_STATUS_OPEN] owner1_enter{ownerPositions[1] = OWNER_POS_IN;} -> owner_pos()
    []
    [ownerPositions[1] == OWNER_POS_IN && doorStatus == DOOR_STATUS_OPEN] owner1_exit{ownerPositions[1] = OWNER_POS_NEAR;} -> owner_pos()
    []
    [ownerPositions[1] == OWNER_POS_NEAR] owner1_leave{ownerPositions[1] = OWNER_POS_FAR;} -> owner_pos();

key_pos() = 
    [keyPosition == KEY_POS_FAR && ownerPositions[0] == OWNER_POS_NEAR] pickup_key_by_owner0{keyPosition = KEY_POS_WITH_OWNER;} -> key_pos()
    []
    [keyPosition == KEY_POS_FAR && ownerPositions[1] == OWNER_POS_NEAR] pickup_key_by_owner1{keyPosition = KEY_POS_WITH_OWNER;} -> key_pos()
    []
    [keyPosition == KEY_POS_WITH_OWNER && ownerPositions[0] == OWNER_POS_IN] key_set_in_car_by_owner0{keyPosition = KEY_POS_IN;} -> key_pos()
    []
    [keyPosition == KEY_POS_WITH_OWNER && ownerPositions[1] == OWNER_POS_IN] key_set_in_car_by_owner1{keyPosition = KEY_POS_IN;} -> key_pos()
    []
    [keyPosition == KEY_POS_IN && ownerPositions[0] == OWNER_POS_IN && doorStatus == DOOR_STATUS_OPEN] key_exit_car_by_owner0{keyPosition = KEY_POS_WITH_OWNER;} -> key_pos()
    []
    [keyPosition == KEY_POS_IN && ownerPositions[1] == OWNER_POS_IN && doorStatus == DOOR_STATUS_OPEN] key_exit_car_by_owner1{keyPosition = KEY_POS_WITH_OWNER;} -> key_pos()
    []
    [keyPosition == KEY_POS_WITH_OWNER && ownerPositions[0] == OWNER_POS_FAR] drop_key_far_by_owner0{keyPosition = KEY_POS_FAR;} -> key_pos()
    []
    [keyPosition == KEY_POS_WITH_OWNER && ownerPositions[1] == OWNER_POS_FAR] drop_key_far_by_owner1{keyPosition = KEY_POS_FAR;} -> key_pos();

door_op() =
    [doorStatus == DOOR_STATUS_LOCKED && ownerPositions[0] == OWNER_POS_NEAR && keyPosition == KEY_POS_WITH_OWNER] unlock_door_by_owner0{doorStatus = DOOR_STATUS_UNLOCKED;} -> door_op()
    []
    [doorStatus == DOOR_STATUS_LOCKED && ownerPositions[1] == OWNER_POS_NEAR && keyPosition == KEY_POS_WITH_OWNER] unlock_door_by_owner1{doorStatus = DOOR_STATUS_UNLOCKED;} -> door_op()
    []
    [doorStatus == DOOR_STATUS_LOCKED && ownerPositions[0] == OWNER_POS_IN] unlock_door_from_inside_owner0{doorStatus = DOOR_STATUS_UNLOCKED;} -> door_op()
    []
    [doorStatus == DOOR_STATUS_LOCKED && ownerPositions[1] == OWNER_POS_IN] unlock_door_from_inside_owner1{doorStatus = DOOR_STATUS_UNLOCKED;} -> door_op()
    []
    [doorStatus == DOOR_STATUS_UNLOCKED] open_door{doorStatus = DOOR_STATUS_OPEN;} -> door_op()
    []
    [doorStatus == DOOR_STATUS_OPEN] close_door{doorStatus = DOOR_STATUS_UNLOCKED;} -> door_op()
    []
    [doorStatus == DOOR_STATUS_UNLOCKED && ownerPositions[0] == OWNER_POS_FAR && ownerPositions[1] == OWNER_POS_FAR && keyPosition == KEY_POS_FAR] lock_door{doorStatus = DOOR_STATUS_LOCKED;} -> door_op();

motor() =
    [engineState == ENGINE_OFF && ownerPositions[0] == OWNER_POS_IN && (fuelLevel == FUEL_FULL || fuelLevel == FUEL_HALF)] start_engine_by_owner0{engineState = ENGINE_ON;} -> motor()
    []
    [engineState == ENGINE_OFF && ownerPositions[1] == OWNER_POS_IN && (fuelLevel == FUEL_FULL || fuelLevel == FUEL_HALF)] start_engine_by_owner1{engineState = ENGINE_ON;} -> motor()
    []
    [engineState == ENGINE_ON && carMotion == CAR_STOPPED] stop_engine{engineState = ENGINE_OFF;} -> motor()
    []
    [engineState == ENGINE_ON && carMotion == CAR_STOPPED && (fuelLevel == FUEL_FULL || fuelLevel == FUEL_HALF)] start_driving{carMotion = CAR_DRIVING;} -> motor()
    []
    [engineState == ENGINE_ON && carMotion == CAR_DRIVING] stop_driving{carMotion = CAR_STOPPED;} -> motor()
    []
    [carMotion == CAR_DRIVING && fuelLevel == FUEL_FULL] consume_fuel_full_to_half{fuelLevel = FUEL_HALF;} -> motor()
    []
    [carMotion == CAR_DRIVING && fuelLevel == FUEL_HALF] consume_fuel_half_to_empty{fuelLevel = FUEL_EMPTY;} -> motor()
    []
    [engineState == ENGINE_OFF && carMotion == CAR_STOPPED && fuelLevel == FUEL_EMPTY] refuel_from_empty{fuelLevel = FUEL_FULL;} -> motor()
    []
    [engineState == ENGINE_OFF && carMotion == CAR_STOPPED && fuelLevel == FUEL_HALF] refuel_from_half{fuelLevel = FUEL_FULL;} -> motor();

keyless_car = (owner_pos() ||| key_pos() ||| door_op() ||| motor());

#define keylockinside (keyPosition == KEY_POS_IN && doorStatus == DOOR_STATUS_LOCKED && ownerPositions[0] != OWNER_POS_IN && ownerPositions[1] != OWNER_POS_IN);
#define runwithoutowner (carMotion == CAR_DRIVING && ownerPositions[0] == OWNER_POS_FAR && ownerPositions[1] == OWNER_POS_FAR);
#define ownerdrivetogether (carMotion == CAR_DRIVING && ownerPositions[0] == OWNER_POS_IN && ownerPositions[1] == OWNER_POS_IN);
#define drivewithoutengineon (carMotion == CAR_DRIVING && engineState == ENGINE_OFF);
#define drivewithoutfuel (carMotion == CAR_DRIVING && fuelLevel == FUEL_EMPTY);
#define drivewithoutkeyholdbyother (carMotion == CAR_DRIVING && ownerPositions[1] == OWNER_POS_IN && ownerPositions[0] == OWNER_POS_FAR && keyPosition == KEY_POS_WITH_OWNER);
#assert keyless_car deadlockfree;
#assert keyless_car |= []<> start_driving;
#assert keyless_car reaches keylockinside;
#assert keyless_car reaches runwithoutowner;
#assert keyless_car reaches ownerdrivetogether;
#assert keyless_car reaches drivewithoutengineon;
#assert keyless_car reaches drivewithoutfuel;
#assert keyless_car reaches drivewithoutkeyholdbyother;