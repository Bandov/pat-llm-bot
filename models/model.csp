#define TELE_LINE_IDLE 0;
#define TELE_LINE_BUSY 1;
#define USER_COUNT 4;
#define USER_ONHOOK_IDLE 10;
#define USER_DIALING 11;
#define USER_WAITING 12;
#define USER_ANSWERING 13;
#define USER_IGNORING 14;
#define USER_ENGAGED 15;
#define USER_HANGING_UP 16;

var lineState = TELE_LINE_IDLE;
var handsetStates[USER_COUNT] = [USER_ONHOOK_IDLE, USER_ONHOOK_IDLE, USER_ONHOOK_IDLE, USER_ONHOOK_IDLE];

tele_line(caller, target) = 
    [lineState == TELE_LINE_IDLE && handsetStates[caller] == USER_DIALING && handsetStates[target] == USER_ONHOOK_IDLE] 
    initiate_ringing_call{lineState = TELE_LINE_BUSY; handsetStates[caller] = USER_WAITING; handsetStates[target] = USER_WAITING;} -> tele_line(caller, target)
    []
    [lineState == TELE_LINE_IDLE && handsetStates[caller] == USER_DIALING && 
     (handsetStates[target] == USER_DIALING || handsetStates[target] == USER_WAITING || 
      handsetStates[target] == USER_ANSWERING || handsetStates[target] == USER_IGNORING || 
      handsetStates[target] == USER_ENGAGED || handsetStates[target] == USER_HANGING_UP)]
    initiate_busy_call{lineState = TELE_LINE_BUSY; handsetStates[caller] = USER_WAITING;} -> tele_line(caller, target)
    []
    [lineState == TELE_LINE_BUSY && handsetStates[caller] == USER_WAITING && handsetStates[target] == USER_ANSWERING]
    connect_call{handsetStates[caller] = USER_ENGAGED; handsetStates[target] = USER_ENGAGED;} -> tele_line(caller, target)
    []
    [lineState == TELE_LINE_BUSY && handsetStates[caller] == USER_HANGING_UP && handsetStates[target] == USER_ENGAGED]
    disconnect_call_caller{lineState = TELE_LINE_IDLE; handsetStates[caller] = USER_ONHOOK_IDLE; handsetStates[target] = USER_ONHOOK_IDLE;} -> tele_line(caller, target)
    []
    [lineState == TELE_LINE_BUSY && handsetStates[caller] == USER_ENGAGED && handsetStates[target] == USER_HANGING_UP]
    disconnect_call_target{lineState = TELE_LINE_IDLE; handsetStates[caller] = USER_ONHOOK_IDLE; handsetStates[target] = USER_ONHOOK_IDLE;} -> tele_line(caller, target)
    []
    [lineState == TELE_LINE_BUSY && handsetStates[caller] == USER_WAITING && 
     (handsetStates[target] == USER_DIALING || handsetStates[target] == USER_WAITING || 
      handsetStates[target] == USER_ANSWERING || handsetStates[target] == USER_IGNORING || 
      handsetStates[target] == USER_ENGAGED || handsetStates[target] == USER_HANGING_UP)]
    reset_after_busy{lineState = TELE_LINE_IDLE; handsetStates[caller] = USER_ONHOOK_IDLE;} -> tele_line(caller, target);

user(i) = 
    [handsetStates[i] == USER_ONHOOK_IDLE]
    start_dial{handsetStates[i] = USER_DIALING;} -> user(i)
    []
    [handsetStates[i] == USER_WAITING]
    answer_incoming_call{handsetStates[i] = USER_ANSWERING;} -> user(i)
    []
    [handsetStates[i] == USER_WAITING]
    ignore_incoming_call{handsetStates[i] = USER_IGNORING;} -> user(i)
    []
    [handsetStates[i] == USER_ENGAGED]
    hang_up{handsetStates[i] = USER_HANGING_UP;} -> user(i)
    []
    [handsetStates[i] == USER_HANGING_UP]
    complete_hang_up{handsetStates[i] = USER_ONHOOK_IDLE;} -> user(i);

telecom_service = (||| i:{0..USER_COUNT-1} @ user(i)) ||| (||| caller:{0..USER_COUNT-1} @ (||| target:{0..USER_COUNT-1} @ [caller != target]tele_line(caller, target)));

#define user0_connected_to_user1 (handsetStates[0] == USER_ENGAGED && handsetStates[1] == USER_ENGAGED);
#define all_user_on_call (handsetStates[0] == USER_ENGAGED && handsetStates[1] == USER_ENGAGED && handsetStates[2] == USER_ENGAGED && handsetStates[3] == USER_ENGAGED);
#define user2_in_call (handsetStates[2] == USER_ENGAGED);
#define user3_in_call (handsetStates[3] == USER_ENGAGED);
#assert telecom_service deadlockfree;
#assert telecom_service reaches user0_connected_to_user1;
#assert telecom_service reaches all_user_on_call;
#assert telecom_service |= [](user0_connected_to_user1 -> (!user2_in_call && !user3_in_call));