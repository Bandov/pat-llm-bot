#define ENGINE_OFF 0;
#define ENGINE_ON 1;
#define DRIVING_STOPPED 2;
#define DRIVING_DRIVING 3;
#define FUEL_EMPTY 4;
#define FUEL_LOW 5;
#define FUEL_MEDIUM 6;
#define FUEL_FULL 7;
#define DOOR_OPEN 8;
#define DOOR_UNLOCKED 9;
#define DOOR_LOCKED 10;
#define CAR_IN 11;
#define CAR_FAR 12;
#define KEY_WITH_OWNER 13;
#define OWNER_NEAR 14;
#define WINDOW_OPEN 16;
#define WINDOW_HALF_OPENED 17;
#define WINDOW_CLOSED 18;

var engineStatus = ENGINE_OFF;
var drivingStatus = DRIVING_STOPPED;
var fuelLevel = FUEL_FULL;
var doorStatus = DOOR_LOCKED;
var keyPosition = KEY_WITH_OWNER;
var ownerPositions[2] = [CAR_FAR, CAR_FAR];
var windowStatus = WINDOW_CLOSED;
var turn = 0;
var emergency_occurred = 0;

Motor() = 
    [turn == 6] turn_engine_on{engineStatus = ENGINE_ON; turn = 61;} -> Motor()
    []
    [turn == 6] skip_engine{engineStatus = ENGINE_OFF; turn = 61;} -> Motor()
    []
    [turn == 61] fill_fuel{fuelLevel = FUEL_FULL; turn = 7;} -> Motor()
    []
    [turn == 61] drain_fuel{fuelLevel = FUEL_EMPTY; turn = 7;} -> Motor()
    []
    [turn == 7] start_driving{drivingStatus = DRIVING_DRIVING; turn = 8;} -> Motor()
    []
    [turn == 8] stop_driving{drivingStatus = DRIVING_STOPPED; turn = 9;} -> Motor()
    []
    [turn == 8] engine_failure{engineStatus = ENGINE_OFF; drivingStatus = DRIVING_STOPPED; turn = 9;} -> Motor()
    []
    [turn == 0 || turn == 1 || turn == 2 || turn == 3 || turn == 4 || turn == 5 || turn == 9] motor_idle -> Motor();

Door() = 
    [turn == 1] unlock_door{doorStatus = DOOR_UNLOCKED; turn = 2;} -> Door()
    []
    [turn == 3] open_door{doorStatus = DOOR_OPEN; turn = 4;} -> Door()
    []
    [turn == 5] close_door{doorStatus = DOOR_LOCKED; turn = 6;} -> Door()
    []
    [turn == 5] prevent_lockout{doorStatus = DOOR_UNLOCKED; turn = 6;} -> Door()
    []
    [turn == 0 || turn == 2 || turn == 4 || turn == 6 || turn == 61 || turn == 7 || turn == 8 || turn == 9] door_idle -> Door();

Key() = 
    [turn == 2] key_to_car{keyPosition = CAR_IN; turn = 3;} -> Key()
    []
    [turn == 2] key_to_owner{keyPosition = KEY_WITH_OWNER; turn = 3;} -> Key()
    []
    [turn == 2] key_to_far{keyPosition = CAR_FAR; turn = 3;} -> Key()
    []
    [turn == 0 || turn == 1 || turn == 3 || turn == 4 || turn == 5 || turn == 6 || turn == 61 || turn == 7 || turn == 8 || turn == 9] key_idle -> Key();

Owner() = 
    [turn == 0] finish_move{turn = 1;} -> Owner()
    []
    [turn == 4] owner1_enter{ownerPositions[0] = CAR_IN; turn = 5;} -> Owner()
    []
    [turn == 4] owner2_enter{ownerPositions[1] = CAR_IN; turn = 5;} -> Owner()
    []
    [turn == 4] both_enter{ownerPositions[0] = CAR_IN; ownerPositions[1] = CAR_IN; turn = 5;} -> Owner()
    []
    [turn == 4] skip_enter{turn = 5;} -> Owner()
    []
    [turn == 8] owners_jump_out{ownerPositions[0] = CAR_FAR; ownerPositions[1] = CAR_FAR; turn = 9;} -> Owner()
    []
    [turn == 1 || turn == 2 || turn == 3 || turn == 5 || turn == 6 || turn == 61 || turn == 7 || turn == 9] owner_idle -> Owner();

Window() = 
    [turn == 9] window_close{windowStatus = WINDOW_CLOSED; turn = 0;} -> Window()
    []
    [turn == 9] window_open{windowStatus = WINDOW_OPEN; turn = 0;} -> Window()
    []
    [turn == 0 || turn == 1 || turn == 2 || turn == 3 || turn == 4 || turn == 5 || turn == 6 || turn == 61 || turn == 7 || turn == 8] window_idle -> Window();

tesla() = (Motor() ||| Door() ||| Key() ||| Owner() ||| Window()) 
          interrupt ([emergency_occurred == 0] water_sensor_high{doorStatus = DOOR_UNLOCKED; windowStatus = WINDOW_OPEN; emergency_occurred = 1; turn = 0;} -> submerge -> stop_driving_emergency{drivingStatus = DRIVING_STOPPED; engineStatus = ENGINE_OFF; emergency_occurred = 0; turn = 0;} -> tesla());

#define openAll (doorStatus == DOOR_UNLOCKED && windowStatus == WINDOW_OPEN);
#define keylockinside (keyPosition == CAR_IN && doorStatus == DOOR_LOCKED && ownerPositions[0] != CAR_IN && ownerPositions[1] != CAR_IN);
#define runwithoutowner (drivingStatus == DRIVING_DRIVING && ownerPositions[0] == CAR_FAR && ownerPositions[1] == CAR_FAR);
#define ownerdrivetogether (drivingStatus == DRIVING_DRIVING && ownerPositions[0] == CAR_IN && ownerPositions[1] == CAR_IN);
#define drivewithoutengineon (drivingStatus == DRIVING_DRIVING && engineStatus == ENGINE_OFF);
#define drivewithoutfuel (drivingStatus == DRIVING_DRIVING && fuelLevel == FUEL_EMPTY);
#define drivewithoutkeyholdbyother (drivingStatus == DRIVING_DRIVING && ownerPositions[1] == CAR_IN && ownerPositions[0] == CAR_FAR && keyPosition == KEY_WITH_OWNER);

#assert tesla() |= water_sensor_high -> X openAll;
#assert tesla() |= []<> start_driving;
#assert tesla() reaches keylockinside;
#assert tesla() reaches runwithoutowner;
#assert tesla() reaches ownerdrivetogether;
#assert tesla() reaches drivewithoutengineon;
#assert tesla() reaches drivewithoutfuel;
#assert tesla() reaches drivewithoutkeyholdbyother;