#define STATION_ENTRY 0;
#define STATION_TRACK1 1;
#define STATION_TRACK2 2;
#define STATION_EXIT 3;
#define SIGNAL_GREEN 0;
#define SIGNAL_RED 1;

var Track1_signal = SIGNAL_GREEN;
var Track2_signal = SIGNAL_GREEN;
var Train1_position = STATION_ENTRY;
var Train2_position = STATION_ENTRY;

Track1() = 
        [(Train1_position == STATION_ENTRY || Train1_position == STATION_TRACK1 || Train1_position == STATION_TRACK2) && 
        (Train2_position == STATION_ENTRY || Train2_position == STATION_TRACK1 || Train2_position == STATION_TRACK2) && 
        Track1_signal == SIGNAL_RED] 
        Track1_set_green{Track1_signal = SIGNAL_GREEN;} -> Track1()
        [] 
        [Train1_position == STATION_EXIT && Track1_signal == SIGNAL_GREEN] 
        Track1_set_red_train1{Track1_signal = SIGNAL_RED;} -> Track1()
        [] 
        [Train2_position == STATION_EXIT && Track1_signal == SIGNAL_GREEN] 
        Track1_set_red_train2{Track1_signal = SIGNAL_RED;} -> Track1();

Track2() = 
        [(Train1_position == STATION_ENTRY || Train1_position == STATION_TRACK1 || Train1_position == STATION_TRACK2) && 
        (Train2_position == STATION_ENTRY || Train2_position == STATION_TRACK1 || Train2_position == STATION_TRACK2) && 
        Track2_signal == SIGNAL_RED] 
        Track2_set_green{Track2_signal = SIGNAL_GREEN;} -> Track2()
        [] 
        [Train1_position == STATION_EXIT && Track2_signal == SIGNAL_GREEN] 
        Track2_set_red_train1{Track2_signal = SIGNAL_RED;} -> Track2()
        [] 
        [Train2_position == STATION_EXIT && Track2_signal == SIGNAL_GREEN] 
        Track2_set_red_train2{Track2_signal = SIGNAL_RED;} -> Track2();

Train1() = 
        [Train1_position == STATION_ENTRY && Track1_signal == SIGNAL_GREEN && 
        (Train2_position == STATION_ENTRY || Train2_position == STATION_TRACK2 || Train2_position == STATION_EXIT)] 
        Train1_move_entry_to_track1{Train1_position = STATION_TRACK1;} -> Train1()
        [] 
        [Train1_position == STATION_ENTRY && Track2_signal == SIGNAL_GREEN && 
        (Train2_position == STATION_ENTRY || Train2_position == STATION_TRACK1 || Train2_position == STATION_EXIT)] 
        Train1_move_entry_to_track2{Train1_position = STATION_TRACK2;} -> Train1()
        [] 
        [Train1_position == STATION_TRACK1 && Track1_signal == SIGNAL_GREEN && 
        (Train2_position == STATION_ENTRY || Train2_position == STATION_TRACK1 || Train2_position == STATION_TRACK2)] 
        Train1_move_track1_to_exit{Train1_position = STATION_EXIT;} -> Train1()
        [] 
        [Train1_position == STATION_TRACK2 && Track2_signal == SIGNAL_GREEN && 
        (Train2_position == STATION_ENTRY || Train2_position == STATION_TRACK1 || Train2_position == STATION_TRACK2)] 
        Train1_move_track2_to_exit{Train1_position = STATION_EXIT;} -> Train1();

Train2() = 
        [Train2_position == STATION_ENTRY && Track1_signal == SIGNAL_GREEN && 
        (Train1_position == STATION_ENTRY || Train1_position == STATION_TRACK2 || Train1_position == STATION_EXIT)] 
        Train2_move_entry_to_track1{Train2_position = STATION_TRACK1;} -> Train2()
        [] 
        [Train2_position == STATION_ENTRY && Track2_signal == SIGNAL_GREEN && 
        (Train1_position == STATION_ENTRY || Train1_position == STATION_TRACK1 || Train1_position == STATION_EXIT)] 
        Train2_move_entry_to_track2{Train2_position = STATION_TRACK2;} -> Train2()
        [] 
        [Train2_position == STATION_TRACK1 && Track1_signal == SIGNAL_GREEN && 
        (Train1_position == STATION_ENTRY || Train1_position == STATION_TRACK1 || Train1_position == STATION_TRACK2)] 
        Train2_move_track1_to_exit{Train2_position = STATION_EXIT;} -> Train2()
        [] 
        [Train2_position == STATION_TRACK2 && Track2_signal == SIGNAL_GREEN && 
        (Train1_position == STATION_ENTRY || Train1_position == STATION_TRACK1 || Train1_position == STATION_TRACK2)] 
        Train2_move_track2_to_exit{Train2_position = STATION_EXIT;} -> Train2();

railwaysys = Track1() ||| Track2() ||| Train1() ||| Train2();

#define Track1_green (Track1_signal == SIGNAL_GREEN);
#define Track2_green (Track2_signal == SIGNAL_GREEN);
#define Collision (Train1_position == Train2_position);
#define Train1_at_Track1 (Train1_position == STATION_TRACK1);
#define Train1_at_Exit (Train1_position == STATION_EXIT);
#define At_most_one_green (!((Track1_signal == SIGNAL_GREEN) && (Track2_signal == SIGNAL_GREEN)));
#assert railwaysys |= <>Track1_green;
#assert railwaysys |= <>Track2_green;
#assert railwaysys |= [](!Collision);
#assert railwaysys |= [](Train1_at_Track1 -> (!Track1_green -> [](!Train1_at_Exit)));
#assert railwaysys |= []At_most_one_green;