#define ENGINE_OFF 0;
#define ENGINE_ON 1;
#define DRIVING_STOPPED 2;
#define DRIVING_DRIVING 3;
#define FUEL_EMPTY 4;
#define FUEL_LOW 5;
#define FUEL_MEDIUM 6;
#define FUEL_FULL 7;
#define DOOR_OPEN 8;
#define DOOR_UNLOCKED 9;
#define DOOR_LOCKED 10;
#define CAR_IN 11;
#define CAR_FAR 12;
#define KEY_WITH_OWNER 13;
#define OWNER_NEAR 14;
#define OWNER_COUNT 15;
#define WINDOW_OPEN 16;
#define WINDOW_HALF_OPENED 17;
#define WINDOW_CLOSED 18;

var engineStatus = ENGINE_OFF;
var drivingStatus = DRIVING_STOPPED;
var fuelLevel = FUEL_FULL;
var doorStatus = DOOR_LOCKED;
var keyPosition = KEY_WITH_OWNER;
var ownerPositions[2] = [CAR_FAR, CAR_FAR];
var windowStatus = WINDOW_CLOSED;

motor() = 
    [engineStatus == ENGINE_OFF && (fuelLevel == FUEL_LOW || fuelLevel == FUEL_MEDIUM || fuelLevel == FUEL_FULL)] turn_engine_on{engineStatus = ENGINE_ON;} -> motor()
    []
    [engineStatus == ENGINE_ON && drivingStatus == DRIVING_STOPPED] turn_engine_off{engineStatus = ENGINE_OFF;} -> motor()
    []
    [engineStatus == ENGINE_ON && drivingStatus == DRIVING_STOPPED && (fuelLevel == FUEL_LOW || fuelLevel == FUEL_MEDIUM || fuelLevel == FUEL_FULL)] start_driving{drivingStatus = DRIVING_DRIVING;} -> motor()
    []
    [engineStatus == ENGINE_ON && drivingStatus == DRIVING_DRIVING] stop_driving{drivingStatus = DRIVING_STOPPED;} -> motor()
    []
    [drivingStatus == DRIVING_DRIVING && fuelLevel == FUEL_FULL] consume_fuel_full_to_medium{fuelLevel = FUEL_MEDIUM;} -> motor()
    []
    [drivingStatus == DRIVING_DRIVING && fuelLevel == FUEL_MEDIUM] consume_fuel_medium_to_low{fuelLevel = FUEL_LOW;} -> motor()
    []
    [drivingStatus == DRIVING_DRIVING && fuelLevel == FUEL_LOW] consume_fuel_low_to_empty{fuelLevel = FUEL_EMPTY;} -> motor()
    []
    [engineStatus == ENGINE_OFF && drivingStatus == DRIVING_STOPPED && (fuelLevel == FUEL_EMPTY || fuelLevel == FUEL_LOW || fuelLevel == FUEL_MEDIUM)] refuel{fuelLevel = FUEL_FULL;} -> motor();

door_op() = 
    [doorStatus == DOOR_LOCKED && (ownerPositions[0] == CAR_IN || ownerPositions[0] == OWNER_NEAR)] unlock_door_owner1{doorStatus = DOOR_UNLOCKED;} -> door_op()
    []
    [doorStatus == DOOR_LOCKED && (ownerPositions[1] == CAR_IN || ownerPositions[1] == OWNER_NEAR)] unlock_door_owner2{doorStatus = DOOR_UNLOCKED;} -> door_op()
    []
    [doorStatus == DOOR_LOCKED && keyPosition == CAR_IN] unlock_door_with_key{doorStatus = DOOR_UNLOCKED;} -> door_op()
    []
    [doorStatus == DOOR_UNLOCKED] open_door{doorStatus = DOOR_OPEN;} -> door_op()
    []
    [doorStatus == DOOR_OPEN] close_door{doorStatus = DOOR_UNLOCKED;} -> door_op()
    []
    [doorStatus == DOOR_UNLOCKED] lock_door{doorStatus = DOOR_LOCKED;} -> door_op();

key_pos() = 
    [keyPosition == KEY_WITH_OWNER] key_to_car{keyPosition = CAR_IN;} -> key_pos()
    []
    [keyPosition == KEY_WITH_OWNER] key_to_far{keyPosition = CAR_FAR;} -> key_pos()
    []
    [(keyPosition == CAR_IN || keyPosition == CAR_FAR)] key_to_owner{keyPosition = KEY_WITH_OWNER;} -> key_pos();

owner_pos() = 
    [ownerPositions[0] == OWNER_NEAR] owner1_enter{ownerPositions[0] = CAR_IN;} -> owner_pos()
    []
    [ownerPositions[0] == CAR_IN] owner1_exit{ownerPositions[0] = OWNER_NEAR;} -> owner_pos()
    []
    [ownerPositions[0] == CAR_FAR] owner1_move_near{ownerPositions[0] = OWNER_NEAR;} -> owner_pos()
    []
    [ownerPositions[0] == OWNER_NEAR] owner1_move_far{ownerPositions[0] = CAR_FAR;} -> owner_pos()
    []
    [ownerPositions[1] == OWNER_NEAR] owner2_enter{ownerPositions[1] = CAR_IN;} -> owner_pos()
    []
    [ownerPositions[1] == CAR_IN] owner2_exit{ownerPositions[1] = OWNER_NEAR;} -> owner_pos()
    []
    [ownerPositions[1] == CAR_FAR] owner2_move_near{ownerPositions[1] = OWNER_NEAR;} -> owner_pos()
    []
    [ownerPositions[1] == OWNER_NEAR] owner2_move_far{ownerPositions[1] = CAR_FAR;} -> owner_pos();

window() = 
    [windowStatus == WINDOW_CLOSED] open_window_from_closed{windowStatus = WINDOW_OPEN;} -> window()
    []
    [windowStatus == WINDOW_HALF_OPENED] open_window_from_half_opened{windowStatus = WINDOW_OPEN;} -> window()
    []
    [windowStatus == WINDOW_CLOSED] half_open_window{windowStatus = WINDOW_HALF_OPENED;} -> window()
    []
    [(windowStatus == WINDOW_OPEN || windowStatus == WINDOW_HALF_OPENED)] close_window{windowStatus = WINDOW_CLOSED;} -> window();

tesla = (motor() ||| door_op() ||| key_pos() ||| owner_pos() ||| window()) interrupt (water_sensor_high -> submerge -> Stop);

#define openAll (doorStatus == DOOR_UNLOCKED && windowStatus == WINDOW_OPEN);
#define keylockinside (keyPosition == CAR_IN && doorStatus == DOOR_LOCKED && ownerPositions[0] != CAR_IN && ownerPositions[1] != CAR_IN);
#define runwithoutowner (drivingStatus == DRIVING_DRIVING && ownerPositions[0] == CAR_FAR && ownerPositions[1] == CAR_FAR);
#define ownerdrivetogether (drivingStatus == DRIVING_DRIVING && ownerPositions[0] == CAR_IN && ownerPositions[1] == CAR_IN);
#define drivewithoutengineon (drivingStatus == DRIVING_DRIVING && engineStatus == ENGINE_OFF);
#define drivewithoutfuel (drivingStatus == DRIVING_DRIVING && fuelLevel == FUEL_EMPTY);
#define drivewithoutkeyholdbyother (drivingStatus == DRIVING_DRIVING && ownerPositions[1] == CAR_IN && ownerPositions[0] == CAR_FAR && keyPosition == KEY_WITH_OWNER);
#assert tesla |= water_sensor_high -> X openAll;
#assert tesla |= []<> start_driving;
#assert tesla reaches keylockinside;
#assert tesla reaches runwithoutowner;
#assert tesla reaches ownerdrivetogether;
#assert tesla reaches drivewithoutengineon;
#assert tesla reaches drivewithoutfuel;
#assert tesla reaches drivewithoutkeyholdbyother;