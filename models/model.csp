#define NUM_COMPONENTS 2;
#define NO_ASSEMBLY 0;
#define COMPONENT1_ID 1;
#define COMPONENT2_ID 2;
#define PRODUCT_ID 3;

var Component1_position = 0;
var Component2_position = 0;
var Product_position = 0;
var Robot1_position = 0;
var Robot1_assemblingItem = NO_ASSEMBLY;
var Robot2_position = 0;
var Robot2_assemblingItem = NO_ASSEMBLY;

Component1() = 
    [Robot1_assemblingItem == COMPONENT1_ID] assemble_component1_Robot1{Component1_position = Robot1_position;} -> Component1()
    []
    [Robot2_assemblingItem == COMPONENT1_ID] assemble_component1_Robot2{Component1_position = Robot2_position;} -> Component1();

Component2() = 
    [Robot1_assemblingItem == COMPONENT2_ID] assemble_component2_Robot1{Component2_position = Robot1_position;} -> Component2()
    []
    [Robot2_assemblingItem == COMPONENT2_ID] assemble_component2_Robot2{Component2_position = Robot2_position;} -> Component2();

Product() = 
    [Robot1_assemblingItem == PRODUCT_ID && Component1_position >= 1 && Component1_position <= 2 && Component2_position >= 1 && Component2_position <= 2] 
    assemble_product_Robot1{Product_position = Robot1_position;} -> Product()
    []
    [Robot2_assemblingItem == PRODUCT_ID && Component1_position >= 1 && Component1_position <= 2 && Component2_position >= 1 && Component2_position <= 2] 
    assemble_product_Robot2{Product_position = Robot2_position;} -> Product();

Robot1() = 
    move_Robot1_to_0{Robot1_position = 0;} -> Robot1()
    []
    move_Robot1_to_1{Robot1_position = 1;} -> Robot1()
    []
    move_Robot1_to_2{Robot1_position = 2;} -> Robot1()
    []
    [Robot1_assemblingItem == NO_ASSEMBLY] 
    start_assembly_component1_Robot1{Robot1_assemblingItem = COMPONENT1_ID;} -> Robot1()
    []
    [Robot1_assemblingItem == NO_ASSEMBLY] 
    start_assembly_component2_Robot1{Robot1_assemblingItem = COMPONENT2_ID;} -> Robot1()
    []
    [Robot1_assemblingItem == NO_ASSEMBLY && Component1_position >= 1 && Component1_position <= 2 && Component2_position >= 1 && Component2_position <= 2] 
    start_assembly_product_Robot1{Robot1_assemblingItem = PRODUCT_ID;} -> Robot1()
    []
    [Robot1_assemblingItem == COMPONENT1_ID] 
    finish_assembly_component1_Robot1{Component1_position = Robot1_position; Robot1_assemblingItem = NO_ASSEMBLY;} -> Robot1()
    []
    [Robot1_assemblingItem == COMPONENT2_ID] 
    finish_assembly_component2_Robot1{Component2_position = Robot1_position; Robot1_assemblingItem = NO_ASSEMBLY;} -> Robot1()
    []
    [Robot1_assemblingItem == PRODUCT_ID && Component1_position >= 1 && Component1_position <= 2 && Component2_position >= 1 && Component2_position <= 2] 
    finish_assembly_product_Robot1{Product_position = Robot1_position; Robot1_assemblingItem = NO_ASSEMBLY;} -> Robot1();

Robot2() = 
    move_Robot2_to_0{Robot2_position = 0;} -> Robot2()
    []
    move_Robot2_to_1{Robot2_position = 1;} -> Robot2()
    []
    move_Robot2_to_2{Robot2_position = 2;} -> Robot2()
    []
    [Robot2_assemblingItem == NO_ASSEMBLY] 
    start_assembly_component1_Robot2{Robot2_assemblingItem = COMPONENT1_ID;} -> Robot2()
    []
    [Robot2_assemblingItem == NO_ASSEMBLY] 
    start_assembly_component2_Robot2{Robot2_assemblingItem = COMPONENT2_ID;} -> Robot2()
    []
    [Robot2_assemblingItem == NO_ASSEMBLY && Component1_position >= 1 && Component1_position <= 2 && Component2_position >= 1 && Component2_position <= 2] 
    start_assembly_product_Robot2{Robot2_assemblingItem = PRODUCT_ID;} -> Robot2()
    []
    [Robot2_assemblingItem == COMPONENT1_ID] 
    finish_assembly_component1_Robot2{Component1_position = Robot2_position; Robot2_assemblingItem = NO_ASSEMBLY;} -> Robot2()
    []
    [Robot2_assemblingItem == COMPONENT2_ID] 
    finish_assembly_component2_Robot2{Component2_position = Robot2_position; Robot2_assemblingItem = NO_ASSEMBLY;} -> Robot2()
    []
    [Robot2_assemblingItem == PRODUCT_ID && Component1_position >= 1 && Component1_position <= 2 && Component2_position >= 1 && Component2_position <= 2] 
    finish_assembly_product_Robot2{Product_position = Robot2_position; Robot2_assemblingItem = NO_ASSEMBLY;} -> Robot2();

production_line = Component1() ||| Component2() ||| Product() ||| Robot1() ||| Robot2();

#define Component1_ismade (Component1_position != 0);
#define Component1_madeby_robot (Component1_position == Robot1_position || Component1_position == Robot2_position);
#define Component2_ismade (Component2_position != 0);
#define Component2_madeby_robot (Component2_position == Robot1_position || Component2_position == Robot2_position);
#define Product_ismade (Product_position != 0);
#define Product_madeby_robot (Product_position == Robot1_position || Product_position == Robot2_position);
#define Component1_before_Product (Component1_position != 0);
#define Component2_before_Product (Component2_position != 0);
#assert production_line |= [](Component1_ismade -> Component1_madeby_robot);
#assert production_line |= [](Component2_ismade -> Component2_madeby_robot);
#assert production_line |= [](Product_ismade -> Product_madeby_robot);
#assert production_line |= [](Product_ismade -> (Component1_before_Product && Component2_before_Product));