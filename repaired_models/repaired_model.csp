#define ATTENDED 1;
#define NOT_ATTENDED 0;

var Student1_Class1_Attendance = NOT_ATTENDED;
var Student1_Class2_Attendance = NOT_ATTENDED;
var Student2_Class1_Attendance = NOT_ATTENDED;
var Student2_Class2_Attendance = NOT_ATTENDED;
var Student3_Class1_Attendance = NOT_ATTENDED;
var Student3_Class2_Attendance = NOT_ATTENDED;
var Teacher1_Class1_Teaching = NOT_ATTENDED;
var Teacher1_Class2_Teaching = NOT_ATTENDED;
var Teacher2_Class1_Teaching = NOT_ATTENDED;
var Teacher2_Class2_Teaching = NOT_ATTENDED;
var turn = 1;

Student1() =
    [Student1_Class1_Attendance == NOT_ATTENDED && (Teacher1_Class1_Teaching == ATTENDED || Teacher2_Class1_Teaching == ATTENDED)]
        Student1_attend_class1{Student1_Class1_Attendance = ATTENDED;} -> Student1()
    []
    [Student1_Class1_Attendance == ATTENDED]
        Student1_leave_class1{Student1_Class1_Attendance = NOT_ATTENDED;} -> Student1()
    []
    [Student1_Class2_Attendance == NOT_ATTENDED && (Teacher1_Class2_Teaching == ATTENDED || Teacher2_Class2_Teaching == ATTENDED)]
        Student1_attend_class2{Student1_Class2_Attendance = ATTENDED;} -> Student1()
    []
    [Student1_Class2_Attendance == ATTENDED]
        Student1_leave_class2{Student1_Class2_Attendance = NOT_ATTENDED;} -> Student1();
Student2() =
    [Student2_Class1_Attendance == NOT_ATTENDED]
        Student2_attend_class1{Student2_Class1_Attendance = ATTENDED;} -> Student2()
    []
    [Student2_Class1_Attendance == ATTENDED]
        Student2_leave_class1{Student2_Class1_Attendance = NOT_ATTENDED;} -> Student2()
    []
    [Student2_Class2_Attendance == NOT_ATTENDED]
        Student2_attend_class2{Student2_Class2_Attendance = ATTENDED;} -> Student2()
    []
    [Student2_Class2_Attendance == ATTENDED]
        Student2_leave_class2{Student2_Class2_Attendance = NOT_ATTENDED;} -> Student2();
Student3() =
    [Student3_Class1_Attendance == NOT_ATTENDED]
        Student3_attend_class1{Student3_Class1_Attendance = ATTENDED;} -> Student3()
    []
    [Student3_Class1_Attendance == ATTENDED]
        Student3_leave_class1{Student3_Class1_Attendance = NOT_ATTENDED;} -> Student3()
    []
    [Student3_Class2_Attendance == NOT_ATTENDED]
        Student3_attend_class2{Student3_Class2_Attendance = ATTENDED;} -> Student3()
    []
    [Student3_Class2_Attendance == ATTENDED]
        Student3_leave_class2{Student3_Class2_Attendance = NOT_ATTENDED;} -> Student3();

#define Class1_Empty (Student1_Class1_Attendance == NOT_ATTENDED && Student2_Class1_Attendance == NOT_ATTENDED && Student3_Class1_Attendance == NOT_ATTENDED);
#define Class2_Empty (Student1_Class2_Attendance == NOT_ATTENDED && Student2_Class2_Attendance == NOT_ATTENDED && Student3_Class2_Attendance == NOT_ATTENDED);

Teacher1() =
    [turn == 1 && Teacher1_Class1_Teaching == NOT_ATTENDED && Teacher2_Class1_Teaching == NOT_ATTENDED]
        Teacher1_start_teaching_class1{Teacher1_Class1_Teaching = ATTENDED; turn = 2;} -> Teacher1()
    []
    [Teacher1_Class1_Teaching == ATTENDED && Class1_Empty]
        Teacher1_stop_teaching_class1{Teacher1_Class1_Teaching = NOT_ATTENDED;} -> Teacher1()
    []
    [turn == 1 && Teacher1_Class2_Teaching == NOT_ATTENDED && Teacher2_Class2_Teaching == NOT_ATTENDED]
        Teacher1_start_teaching_class2{Teacher1_Class2_Teaching = ATTENDED; turn = 2;} -> Teacher1()
    []
    [Teacher1_Class2_Teaching == ATTENDED && Class2_Empty]
        Teacher1_stop_teaching_class2{Teacher1_Class2_Teaching = NOT_ATTENDED;} -> Teacher1()
    []
    [Teacher1_Class1_Teaching == ATTENDED && Student1_Class1_Attendance == ATTENDED]
        Teacher1_tutor_Student1_class1 -> Teacher1()
    []
    [Teacher1_Class1_Teaching == ATTENDED && Student2_Class1_Attendance == ATTENDED]
        Teacher1_tutor_Student2_class1 -> Teacher1()
    []
    [Teacher1_Class1_Teaching == ATTENDED && Student3_Class1_Attendance == ATTENDED]
        Teacher1_tutor_Student3_class1 -> Teacher1()
    []
    [Teacher1_Class2_Teaching == ATTENDED && Student1_Class2_Attendance == ATTENDED]
        Teacher1_tutor_Student1_class2 -> Teacher1()
    []
    [Teacher1_Class2_Teaching == ATTENDED && Student2_Class2_Attendance == ATTENDED]
        Teacher1_tutor_Student2_class2 -> Teacher1()
    []
    [Teacher1_Class2_Teaching == ATTENDED && Student3_Class2_Attendance == ATTENDED]
        Teacher1_tutor_Student3_class2 -> Teacher1();
Teacher2() =
    [turn == 2 && Teacher2_Class1_Teaching == NOT_ATTENDED && Teacher1_Class1_Teaching == NOT_ATTENDED]
        Teacher2_start_teaching_class1{Teacher2_Class1_Teaching = ATTENDED; turn = 1;} -> Teacher2()
    []
    [Teacher2_Class1_Teaching == ATTENDED && Class1_Empty]
        Teacher2_stop_teaching_class1{Teacher2_Class1_Teaching = NOT_ATTENDED;} -> Teacher2()
    []
    [turn == 2 && Teacher2_Class2_Teaching == NOT_ATTENDED && Teacher1_Class2_Teaching == NOT_ATTENDED]
        Teacher2_start_teaching_class2{Teacher2_Class2_Teaching = ATTENDED; turn = 1;} -> Teacher2()
    []
    [Teacher2_Class2_Teaching == ATTENDED && Class2_Empty]
        Teacher2_stop_teaching_class2{Teacher2_Class2_Teaching = NOT_ATTENDED;} -> Teacher2()
    []
    [Teacher2_Class1_Teaching == ATTENDED && Student1_Class1_Attendance == ATTENDED]
        Teacher2_tutor_Student1_class1 -> Teacher2()
    []
    [Teacher2_Class1_Teaching == ATTENDED && Student2_Class1_Attendance == ATTENDED]
        Teacher2_tutor_Student2_class1 -> Teacher2()
    []
    [Teacher2_Class1_Teaching == ATTENDED && Student3_Class1_Attendance == ATTENDED]
        Teacher2_tutor_Student3_class1 -> Teacher2()
    []
    [Teacher2_Class2_Teaching == ATTENDED && Student1_Class2_Attendance == ATTENDED]
        Teacher2_tutor_Student1_class2 -> Teacher2()
    []
    [Teacher2_Class2_Teaching == ATTENDED && Student2_Class2_Attendance == ATTENDED]
        Teacher2_tutor_Student2_class2 -> Teacher2()
    []
    [Teacher2_Class2_Teaching == ATTENDED && Student3_Class2_Attendance == ATTENDED]
        Teacher2_tutor_Student3_class2 -> Teacher2();

classroom = Student1() ||| Student2() ||| Student3() ||| Teacher1() ||| Teacher2();

#define Teacher1_assigned (Teacher1_Class1_Teaching == ATTENDED || Teacher1_Class2_Teaching == ATTENDED);
#define Student1_assigned (Student1_Class1_Attendance == ATTENDED || Student1_Class2_Attendance == ATTENDED);
#define Class1_assigned (Teacher1_Class1_Teaching == ATTENDED || Teacher2_Class1_Teaching == ATTENDED);
#define Student1_attend_Class1 (Student1_Class1_Attendance == ATTENDED);
#assert classroom |= []<>Teacher1_assigned;
#assert classroom |= []<>Student1_assigned;
#assert classroom |= [](Student1_attend_Class1 -> Class1_assigned);